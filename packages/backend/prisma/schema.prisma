datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// history schema: each turn we save the player, the tiles used and their coords. Each turn is separated by a '|'
// history always starts by first player to play. We use 'P' + his index for that (P1). Then, we increase this number each turn
// example: P1XBE7x8A9MAPBLCED|Y6F1O2O3  (P1, ExAMPLE, FOO)
// XB <- Word placed vertically (same X). X = B (hex: 11)
// E7x8A9MAPBLCED <- E7: tile 'E' (X = 11, Y = 7), x8: tile '?' (blank with value 'X', X = 11, Y = 8)

model Game {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status            GameStatus @default(WAITING_FOR_USERS)
  currentGameUser   GameUser?  @relation(fields: [currentGameUserId], references: [id])
  currentGameUserId String?    @db.Uuid
  userCount         Int        @db.SmallInt // -32768 to 32767
  tileBag           String
  history           String
  createdAt         DateTime   @default(now())
  gameUsers         GameUser[]

  @@map("games")
}

enum GameStatus {
  WAITING_FOR_USERS
  STARTED
  ENDED
}

model GameUser {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  game         Game     @relation(fields: [gameId], references: [id])
  gameId       String   @db.Uuid
  user         User?    @relation(fields: [userId], references: [id])
  userId       String?  @db.Uuid
  userIndex    Int      @db.SmallInt
  score        Int      @db.SmallInt@default(0)
  tiles        String
  canceled     Boolean  @default(false)
  updatedAt    DateTime @updatedAt
  currentGames Game[]   @relation(name: "current")

  @@unique([gameId, userIndex])
  @@map("game_users")
}

