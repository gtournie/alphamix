generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client-js"
}

// generator prismaClassGenerator {
//   provider   = "prisma-entity-generator"
//   dryRun     = "false"
//   useSwagger = "false"
// }

datasource db {
  provider = "postgresql"
  //  url      = env("DATABASE_URL")
}

model Game {
  id                   BigInt   @id @default(autoincrement())
  isGameOver           Boolean  @default(false)
  //  currentGameUser      GameUser?  @relation(name: "current", fields: [id, currentGameUserIndex], references: [gameId, index])
  currentGameUserIndex Int      @default(0) @db.SmallInt
  userCount            Int      @db.SmallInt // -32768 to 32767
  tileBag              String
  history              String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  //  gameUsers            GameUser[]

  @@map("games")
}

model GameUser {
  //  game         Game     @relation(fields: [gameId], references: [id])
  gameId   BigInt
  //  user         User?    @relation(fields: [userId], references: [id])
  userId   String   @db.Uuid
  index    Int      @db.SmallInt
  score    Int      @default(0) @db.SmallInt
  tiles    String
  accepted Boolean?
  //  currentGames Game[]   @relation(name: "current")

  @@unique([gameId, index])
  @@index([gameId])
  @@map("game_users")
}

model User {
  id        String   @id @db.Uuid
  name      String   @db.VarChar(15)
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  //  gameUsers GameUser[]
  //  users     UserFriend[] @relation(name: "users")
  //  friends   UserFriend[] @relation(name: "friends")

  @@unique([email])
  @@unique([name])
  @@index([name])
  @@map("users")
}

model UserFriend {
  userId   String @db.Uuid
  friendId String @db.Uuid
  //  user     User   @relation(name: "users", fields: [userId], references: [id])
  //  friend   User   @relation(name: "friends", fields: [friendId], references: [id])

  @@unique([userId, friendId])
  @@index([userId, friendId])
  @@map("users_friends")
}
